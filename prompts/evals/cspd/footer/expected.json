            "icon": "fa-solid fa-chalkboard-teacher",
            "title": "Skilled and caring teachers",
            "description": "Our teachers bring learning to life with passion and creativity. They help students thrive and grow academically and socially through fostering their curiosity and individual talents in partnership with families.",
            "link": {
              "text": "More",
              "url": "/learning/great-teachers"
            }
