# ================================================
# ENVIRONMENT FILE STRATEGY
# ================================================
#
# This project uses a layered environment file approach:
#
#   .env.local    - Base config for all environments (your local settings)
#   .env.prod     - Production overrides (e.g., Prisma Accelerate DATABASE_URL)
#   .env.uat      - UAT overrides (optional)
#   .env.staging  - Staging overrides (optional)
#
# Deployment commands:
#   pnpm deploy:vercel:prod    → Uses .env.local + .env.prod
#   pnpm deploy:vercel:uat     → Uses .env.local + .env.uat
#   pnpm deploy:vercel         → Uses .env.local only (preview)
#
# Example .env.prod (only contains overrides):
#   DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=..."
#
# ================================================

# ================================================
# DATABASE CONFIGURATION
# ================================================

# For LOCAL DEVELOPMENT: Use direct Supabase connection
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=30"

# For PRODUCTION (Vercel): Use Prisma Accelerate
# DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"

# Direct connection for Prisma CLI (migrations, introspection)
# Always points to actual database, never Accelerate
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Default for local development
DATABASE_URL="postgresql://username:password@localhost:5432/catalyst_db"

# ================================================
# APPLICATION SETTINGS  
# ================================================
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Catalyst App"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_IS_STUDIO_DEPLOYMENT="true"

STUDIO_QUOTA_ENFORCEMENT_MODE="log"
# Studio integration encryption (set mode to "enabled" when providing a key)
STUDIO_ENCRYPTION_MODE="disabled"
# STUDIO_ENCRYPTION_KEY_ID="v1"
# STUDIO_ENCRYPTION_KEY="base64-encoded-32-byte-key"
# ================================================
# WEBSITE RESOLUTION (Story 8.8)
# ================================================
# Strategy for resolving which website to serve
# Options: domain | subdomain | path | header | test | auto
# - domain: Resolve by full domain (example.com)
# - subdomain: Resolve by subdomain (client1.example.com)
# - path: Resolve by path prefix (/site/website-slug/...)
# - header: Resolve by X-Website-ID header
# - test: Use TEST_WEBSITE_ID (development only)
# - auto: Try all strategies in order
WEBSITE_RESOLUTION_STRATEGY="test"

# For testing/development only - specify a website ID
TEST_WEBSITE_ID="your-test-website-id-here"

# URL Resolution Settings
URL_CASE_INSENSITIVE="false"

# ================================================
# AI CONFIGURATION
# ================================================
# OpenRouter Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key"

# OpenRouter Model Selection
# Available models: https://openrouter.ai/models
# Examples:
# - anthropic/claude-3.5-sonnet (default)
# - openai/gpt-4-turbo
# - google/gemini-pro
# - meta-llama/llama-3-70b-instruct
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
# Import model chain (pipe-delimited). First model is primary, rest are fallbacks.
# Default: google/gemini-3-pro-preview|google/gemini-2.5-flash|anthropic/claude-sonnet-4.5|x-ai/grok-4.1-fast|anthropic/claude-haiku-4.5|openai/gpt-4o-mini
# IMPORT_MODEL_CHAIN="x-ai/grok-4.1-fast:free"

# Import detection token budgets
# IMPORT_DETECT_MAX_TOKENS - Max completion tokens per request (default 90000)
#   This is capped by the model's actual max_completion_tokens from OpenRouter.
#   Increase if you see truncated JSON output (finish_reason: "length").
# IMPORT_DETECT_MAX_TOKENS="90000"

# IMPORT_DETECT_CONTEXT_BUDGET - Combined prompt+completion budget before we auto-clamp max_tokens.
IMPORT_DETECT_CONTEXT_BUDGET="120000"
# Restrict import LLM calls to specific upstream providers (comma separated). Optional.
# Example: IMPORT_MODEL_ALLOWED_PROVIDER="azure,blah"
IMPORT_MODEL_ALLOWED_PROVIDER=""

# ================================================
# AUTHENTICATION
# ================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# Supabase configuration
# - DATABASE_URL points at the Supabase connection pool (pgBouncer) for runtime usage
# - DIRECT_URL / SUPABASE_DB_URL target the direct Postgres port for migrations and tooling
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
DATABASE_URL="postgresql://username:password@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
PRISMA_DISABLE_ADVISORY_LOCKING=1

# ================================================
# EPIC 7 - UNIVERSAL TYPE SYSTEM
# ================================================
# CMS Provider Configuration
# Available providers: optimizely, mock, contentful (future), strapi (future), wordpress (future)
# Use 'mock' for development without CMS credentials
# Use 'auto' to auto-detect based on available credentials
CMS_PROVIDER="auto"
# Disable providers by comma-separated slug list (e.g. "strapi,contentful")
CMS_DISABLED_PROVIDERS="strapi"

# Universal Type System Settings
# Enable dynamic type loading (automatically discovers existing types)
UNIVERSAL_TYPE_DYNAMIC_LOADING="true"

# Cache timeout for type definitions (milliseconds)
UNIVERSAL_TYPE_CACHE_TIMEOUT="60000"

# Confidence threshold for automatic type application (0-100)
# Types with confidence below this threshold require manual review
UNIVERSAL_TYPE_CONFIDENCE_THRESHOLD="70"

# Maximum number of types that can be created in a single session
UNIVERSAL_TYPE_MAX_SESSION_TYPES="50"

# Enable verbose logging for type operations
UNIVERSAL_TYPE_DEBUG="false"

# ================================================
# CMS PROVIDER CONFIGURATIONS
# ================================================
# Optional: override API base URL (defaults to https://api.cms.optimizely.com)
OPTIMIZELY_API_URL="https://api.cms.optimizely.com"

# Optimizely container configuration
# Use different containers for pages vs. blocks/components so items appear in the expected UI location
# Example defaults (replace with your instance-specific values):
OPTIMIZELY_PAGE_CONTAINER="43f936c99b234ea397b261c538ad07c9"
OPTIMIZELY_BLOCK_CONTAINER="e56f85d0e8334e02976a2d11fe4d598c"

# Kontent.ai Management API
KONTENT_ENVIRONMENT_ID="00000000-0000-0000-0000-000000000000"
KONTENT_MANAGEMENT_API_KEY="your-kontent-management-api-key"
KONTENT_LANGUAGE_CODE="default"
# Optional overrides
# KONTENT_BASE_URL="https://manage.kontent.ai/v2"
# KONTENT_RATE_LIMIT_MS=250
# KONTENT_MAX_RETRIES=5

# Provider Performance Settings
# Delay in milliseconds for mock provider (useful for testing loading states)
MOCK_PROVIDER_DELAY="0"
# Enable provider caching
PROVIDER_CACHE_ENABLED="true"
# Cache TTL in seconds
PROVIDER_CACHE_TTL="300"

# ================================================
# FEATURE FLAGS
# ================================================
# Enable/disable specific Epic 7 features
FEATURE_UNIVERSAL_TYPES="true"
FEATURE_AI_GENERATION="true"
FEATURE_PROVIDER_SELECTION="true"
FEATURE_TRANSFORMATION_API="true"
FEATURE_VALIDATION_API="true"
FEATURE_CONFIDENCE_SCORING="true"

# ================================================
# SECURITY BEST PRACTICES
# ================================================
# 1. Never commit .env file to version control
# 2. Generate strong secrets using: openssl rand -base64 32
# 3. Update DATABASE_URL with your actual database credentials
# 4. Configure only the providers you're actually using
# 5. Enable features incrementally in production
# 6. Monitor performance impact of enabled features
# 7. Regularly rotate secrets and API keys


# Export detection (Epic 40 dry-run)
# EXPORT_DETECTION_MODE=off|dry-run|conservative
# EXPORT_DETECTION_MIN_CONFIDENCE=0.6
# EXPORT_ENABLE_MEDIA_RESOLUTION=false

# ================================================
# MEDIA STORAGE
# ================================================
STUDIO_MEDIA_STORAGE_PROVIDER="FILE"
STUDIO_MEDIA_STORAGE_LOCAL_ROOT="./.media-cache"
STUDIO_MEDIA_STORAGE_LOCAL_PUBLIC_URL="http://localhost:3000/media"

# STUDIO_MEDIA_STORAGE_S3_BUCKET=""
# STUDIO_MEDIA_STORAGE_S3_REGION=""
# STUDIO_MEDIA_STORAGE_S3_PUBLIC_BASE_URL=""
# STUDIO_MEDIA_STORAGE_S3_ENDPOINT=""
# STUDIO_MEDIA_STORAGE_S3_FORCE_PATH_STYLE="false"
# STUDIO_MEDIA_STORAGE_S3_ACCESS_KEY_ID=""
# STUDIO_MEDIA_STORAGE_S3_SECRET_ACCESS_KEY=""
# STUDIO_MEDIA_STORAGE_S3_SESSION_TOKEN=""

# ================================================
# LIVE PREVIEW - VERCEL SANDBOX (TKT-054)
# ================================================
# Vercel Sandbox enables real-time preview of websites by running
# isolated Next.js dev servers. Required for live preview in Site Builder.
#
# Get credentials from:
# - Team ID: Vercel Dashboard → Team Settings → General → Team ID
# - Project ID: Vercel Dashboard → Project → Settings → General → Project ID
# - Token: Vercel Dashboard → Account → Tokens (scope to team)
#
# VERCEL_TEAM_ID="team_xxxxxxxxxxxxxxxxxxxx"
# VERCEL_PROJECT_ID="prj_xxxxxxxxxxxxxxxxxxxx"
# VERCEL_TOKEN="your-vercel-access-token"
#
# Optional: Git repository URL for preview template
# Default uses catalyst-preview-sandbox (generated by generate-head with correct Tailwind v3 config)
# Only override if you need a custom template
# PREVIEW_TEMPLATE_REPO_URL="https://github.com/catalystx-digital/catalyst-preview-sandbox.git"
