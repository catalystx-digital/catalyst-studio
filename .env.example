# ================================================
# CATALYST STUDIO - ENVIRONMENT CONFIGURATION
# ================================================
#
# For first-time local development, you only need to set a few values.
# Everything else has sensible defaults or is only needed for advanced/export/AI features.
#
# QUICK START FOR MOST PEOPLE:
#   1. cp .env.example .env
#   2. Set AUTH_SECRET to a random value (see below)
#   3. (Optional) Add OPENROUTER_API_KEY if you want AI import/generation
#
# The seeded demo + visual builder + preview work WITHOUT any AI key or external CMS.
#
# ================================================

# ------------------------------------------------
# REQUIRED FOR LOCAL DEVELOPMENT
# ------------------------------------------------

# Database (defaults work with the included Docker Compose Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/catalyst_studio"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/catalyst_studio"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Strong random secret for session signing (generate one!)
# macOS/Linux:   openssl rand -base64 32
# Windows:       [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET="replace-with-a-random-secret-here"

# ------------------------------------------------
# AI FEATURES (OPTIONAL BUT RECOMMENDED)
# ------------------------------------------------
# Only needed for: AI website import, greenfield generation from prompts,
# and the conversational AI assistant inside the site builder.
#
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# You can also use a chain of models for import detection (pipe separated)
# IMPORT_MODEL_CHAIN="google/gemini-2.5-flash|anthropic/claude-sonnet-4.5|x-ai/grok-4.1-fast"

# ------------------------------------------------
# EXTERNAL CMS EXPORT (OPTIONAL)
# ------------------------------------------------
# The app defaults to the built-in "mock" provider for local testing.
# Set CMS_PROVIDER to test real exports.
#
# Common values: auto | optimizely | kontent | contentstack | mock
CMS_PROVIDER="auto"

# Optimizely CMS (example - only fill what you use)
# OPTIMIZELY_CLIENT_ID="your-client-id"
# OPTIMIZELY_CLIENT_SECRET="your-client-secret"
# OPTIMIZELY_PAGE_CONTAINER="..."
# OPTIMIZELY_BLOCK_CONTAINER="..."

# Kontent.ai (example)
# KONTENT_ENVIRONMENT_ID="..."
# KONTENT_MANAGEMENT_API_KEY="..."

# Contentstack (example)
# CONTENTSTACK_API_KEY="..."
# CONTENTSTACK_MANAGEMENT_TOKEN="..."

# To hide providers from the UI (comma separated)
# CMS_DISABLED_PROVIDERS="strapi,contentful"

# ------------------------------------------------
# EVERYTHING BELOW THIS LINE IS ADVANCED / RARELY NEEDED
# FOR NORMAL LOCAL DEVELOPMENT OR FIRST-TIME USERS
# ------------------------------------------------

# Node / App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Catalyst Studio"

# Usage / Quotas (development friendly)
STUDIO_QUOTA_ENFORCEMENT_MODE="log"

# Encryption for integration secrets (only enable if you need real credentials)
STUDIO_ENCRYPTION_MODE="disabled"
# STUDIO_ENCRYPTION_KEY_ID="v1"
# STUDIO_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# Website resolution strategy (used for public rendering)
# Options: test | domain | subdomain | path | header | auto
WEBSITE_RESOLUTION_STRATEGY="test"
TEST_WEBSITE_ID="test-website"

# Media storage (local file storage is the default and works great)
STUDIO_MEDIA_STORAGE_PROVIDER="FILE"
STUDIO_MEDIA_STORAGE_LOCAL_ROOT="./.media-cache"
STUDIO_MEDIA_STORAGE_LOCAL_PUBLIC_URL="http://localhost:3000/media"

# S3 media storage (only if you want to test S3)
# STUDIO_MEDIA_STORAGE_S3_BUCKET=""
# STUDIO_MEDIA_STORAGE_S3_REGION=""
# STUDIO_MEDIA_STORAGE_S3_PUBLIC_BASE_URL=""
# STUDIO_MEDIA_STORAGE_S3_ACCESS_KEY_ID=""
# STUDIO_MEDIA_STORAGE_S3_SECRET_ACCESS_KEY=""

# Vercel Sandbox preview (only needed if you have Sandbox access and want to test it)
# VERCEL_TEAM_ID=""
# VERCEL_PROJECT_ID=""
# VERCEL_TOKEN=""

# Advanced / internal feature flags and tuning (you almost never need to touch these)
# UNIVERSAL_TYPE_DYNAMIC_LOADING="true"
# FEATURE_AI_GENERATION="true"
# etc.

# For full list of advanced options, see the comments in the original .env.example
# or the source code that reads these variables.
