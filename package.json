{
  "name": "catalyst-studio",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": false,
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build:components": "tsx scripts/generate-component-registry.ts",
    "dev": "cross-env STUDIO_DISABLE_WORKFLOW_PLUGIN=true npm run build:components && cross-env STUDIO_DISABLE_WORKFLOW_PLUGIN=true next dev",
    "dev:workflow": "npm run build:components && next dev",
    "dev:preview": "npm run dev",
    "dev:4000": "cross-env STUDIO_DISABLE_WORKFLOW_PLUGIN=true PORT=4000 npm run build:components && cross-env STUDIO_DISABLE_WORKFLOW_PLUGIN=true PORT=4000 next dev -p 4000",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 STUDIO_NEXT_BUILD_WORKERS=1 npm run build:components && cross-env NODE_OPTIONS=--max-old-space-size=8192 STUDIO_NEXT_BUILD_WORKERS=1 next build",
    "build:no-workflow": "cross-env STUDIO_DISABLE_WORKFLOW_PLUGIN=true tsx scripts/disable-workflow-routes.ts && cross-env STUDIO_DISABLE_WORKFLOW_PLUGIN=true npm run build",
    "build:sandbox-tarball": "tsx scripts/build-sandbox-tarball.ts",
    "start": "next start",
    "lint": "next lint",
    "cms:create": "node scripts/create-cms-component.js",
    "cms:test": "jest lib/studio/components/cms",
    "cms:build": "tsc -p lib/studio/components/cms/tsconfig.json --noEmit",
    "cms:analyze": "cross-env ANALYZE=true npm run build",
    "cms:storybook": "storybook dev -p 6006",
    "test": "jest",
    "test:ci": "jest --runInBand --passWithNoTests --runTestsByPath lib/studio/components/cms/blog/utils/reading-time.test.ts lib/studio/components/site-builder/utils/__tests__/placeholder-graph.test.ts lib/studio/import/utils/__tests__/url-transformer.test.ts lib/utils/__tests__/request-helpers.test.ts lib/studio/page-content/__tests__/normalizer.test.ts lib/studio/headless/ucs/__tests__/page-resolver.test.ts lib/studio/headless/ucs/__tests__/snapshot-builder.test.ts lib/studio/components/cms/_factory/__tests__/factory.test.ts lib/studio/preview/sandbox/__tests__/sandbox-manager.test.ts lib/studio/preview/sandbox/__tests__/no-active-component-map.test.ts app/api/studio/site-builder/components/reorder/__tests__/route.test.ts app/api/studio/site-builder/page-components/[instanceId]/__tests__/patch-overrides.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:watch": "jest --coverage --watch",
    "test:coverage:ci": "jest --coverage --ci --watchAll=false --passWithNoTests",
    "test:coverage:report": "jest --coverage && open coverage/lcov-report/index.html",
    "test:coverage:check": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":80,\"functions\":80,\"lines\":80,\"statements\":80}}'",
    "test:coverage:analyze": "node scripts/coverage-analysis.js",
    "test:coverage:full": "npm run test:coverage && npm run test:coverage:analyze",
    "test:benchmark": "node scripts/test-benchmark.js",
    "test:unit": "jest --testPathPattern='__tests__'",
    "test:integration": "jest --testPathPattern='integration'",
    "test:performance": "jest --detectOpenHandles --forceExit",
    "test:graphql": "cross-env SKIP_DB_SETUP=true jest __tests__/graphql --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:parallel": "playwright test --workers=4",
    "test:e2e:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:report": "playwright show-report",
    "regress:dom-probe": "pnpm tsx scripts/design-system/dom-probe/regression.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "npx tsx prisma/seed/index.ts",
    "db:reset": "prisma migrate reset",
    "db:fresh": "npm run db:reset -- --force --skip-seed && npm run db:generate && npm run db:seed",
    "db:setup": "npm run db:generate && npm run db:migrate && npm run db:seed",
    "db:studio": "prisma studio",
    "test:db:setup": "dotenv -e .env.test -- prisma migrate deploy",
    "test:db:reset": "rm -f test.db test.db-journal && npm run test:db:setup",
    "migrate:content-items": "npx tsx scripts/migrate-content-items.ts",
    "migrate:content-items:rollback": "npx tsx scripts/migrate-content-items.ts rollback",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "bmad:refresh": "bmad-method install -f -i codex",
    "bmad:list": "bmad-method list:agents",
    "bmad:validate": "bmad-method validate",
    "smoke": "pnpm tsx scripts/generate-head/smoke.ts",
    "smoke:contentstack": "tsx scripts/contentstack-export-smoke.ts",
    "cleanup:contentstack": "node scripts/contentstack-cleanup.js",
    "eval:detection": "tsx scripts/eval/detection-runner.ts",
    "eval:detection:component-atlas": "tsx scripts/eval/detection-runner.ts run --dataset component-atlas --report --fail-on-importer-fix"
  },
